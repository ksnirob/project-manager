// Prisma schema for backend deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum InvoiceSource {
  PROJECT_BUDGET
  TASK_BUDGET
  CUSTOM
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      UserRole @default(MEMBER)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  address   String?
  notes     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  invoices Invoice[]

  @@map("client")
}

model Project {
  id                    String        @id @default(cuid())
  title                 String
  type                  String?
  description           String?
  hasProjectCredentials Boolean       @default(false)
  projectUrl            String?
  cpanelUrl             String?
  cpanelUsername        String?
  cpanelPassword        String?
  adminUrl              String?
  adminUsername         String?
  adminPassword         String?
  projectFilesLink      String?       @db.LongText
  status                ProjectStatus @default(PLANNING)
  deadline              DateTime?
  budget                Float?
  clientId              String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks    Task[]
  invoices Invoice[]

  @@map("project")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  order       Int          @default(0)
  budget      Float?
  projectId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@map("task")
}

model Invoice {
  id         String        @id @default(cuid())
  invoiceNo  String        @unique
  amount     Float
  paidAmount Float         @default(0)
  status     InvoiceStatus @default(UNPAID)
  dueDate    DateTime?
  paidAt     DateTime?
  notes      String?
  source     InvoiceSource @default(CUSTOM)
  clientId   String
  projectId  String?
  taskId     String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@index([projectId])
  @@index([taskId])
  @@index([source])
  @@map("invoice")
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  paidAt    DateTime @default(now())
  method    String?
  reference String?
  notes     String?
  invoiceId String
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paidAt])
  @@map("payment")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  read      Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification")
}
